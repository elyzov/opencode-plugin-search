{
  "name": "opencode-plugin-search",
  "version": "0.0.5",
  "description": "An OpenCode plugin providing advanced code search capabilities including AST-based structural search using ast-grep.",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outfile ./dist/index.js --target node --packages=external",
    "watch": "bun build ./src/index.ts --outfile ./dist/index.js --target node --watch --packages=external",
    "typecheck": "biome check && tsc --noEmit",
    "auto": "biome check --fix && tsc --noEmit",
    "test:pack": "bun pm pack --dry-run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elyzov/opencode-plugin-search.git"
  },
  "keywords": [
    "opencode",
    "plugin",
    "search",
    "code-search",
    "ast-grep",
    "agent",
    "code",
    "structural-search"
  ],
  "author": "elyzov",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/elyzov/opencode-plugin-search/issues"
  },
  "homepage": "https://github.com/elyzov/opencode-plugin-search#readme",
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.1.19",
    "@opencode-ai/sdk": "^1.1.19"
  },
  "devDependencies": {
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "^1.3.9",
    "@types/js-yaml": "4.0.9",
    "@types/node": "^25.3.0",
    "@types/puppeteer": "^5.4.7",
    "bun-types": "latest",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "mdream": "^0.16.0",
    "puppeteer-core": "^24.37.5",
    "shescape": "^2.1.8"
  }
}
