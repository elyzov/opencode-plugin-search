{
  "name": "opencode-plugin-ast-grep",
  "version": "0.0.1",
  "description": "An OpenCode plugin for ast-grep(sg) CLI tool for code structural search, lint, and rewriting.",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outfile ./dist/index.js --target node",
    "watch": "bun build ./src/index.ts --outfile ./dist/index.js --target node --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elyzov/opencode-plugin-ast-grep.git"
  },
  "keywords": [
    "opencode",
    "plugin",
    "ast-grep",
    "agent",
    "code",
    "search"
  ],
  "author": "elyzov",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/elyzov/opencode-plugin-ast-grep/issues"
  },
  "homepage": "https://github.com/elyzov/opencode-plugin-ast-grep#readme",
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.1.19",
    "@opencode-ai/sdk": "^1.1.19"
  },
  "devDependencies": {
    "@tsconfig/bun": "^1.0.10",
    "@types/node": "^25.3.0",
    "bun-types": "latest",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "shescape": "^2.1.8"
  }
}
