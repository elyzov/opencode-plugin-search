# Local testing registry (uncomment when testing locally)
# registry=http://localhost:4873/

# Always save exact version
save-exact=true

# Don't create package-lock.json (we use bun.lock)
package-lock=false

# Don't fund requests
fund=false

# Don't show update notifications
update-notifier=false

# Strict SSL verification
strict-ssl=true

# Set if you need to use a proxy
# proxy=http://proxy.company.com:8080/
# https-proxy=http://proxy.company.com:8080/

# Authentication for private registries (store in environment variables instead)
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
//registry.npmjs.org/:always-auth=true
